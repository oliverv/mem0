# =============================================================================
# OpenMemory — environment variables
# Copy this file to .env and fill in the values for your chosen providers.
# =============================================================================

# -----------------------------------------------------------------------------
# Identity
# -----------------------------------------------------------------------------
USER=your_username                        # used as the default memory owner
NEXT_PUBLIC_USER_ID=${USER}
NEXT_PUBLIC_API_URL=http://localhost:8765
FRONTEND_PORT=3001

# =============================================================================
# LLM Provider  (pick ONE block, comment out the rest)
# =============================================================================

# --- OpenAI ------------------------------------------------------------------
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# --- xAI (Grok) --------------------------------------------------------------
# LLM_PROVIDER=xai
# LLM_MODEL=grok-2-latest
# XAI_API_KEY=xai-...
# LLM_BASE_URL=https://api.x.ai/v1       # optional override

# --- Google Gemini -----------------------------------------------------------
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.0-flash
# LLM_API_KEY=AIza...
# GEMINI_API_KEY=AIza...                  # alias — either works

# --- Anthropic ---------------------------------------------------------------
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_API_KEY=sk-ant-...

# --- LiteLLM (proxy any provider) -------------------------------------------
# LLM_PROVIDER=litellm
# LLM_MODEL=gpt-4o-mini                  # use litellm model name syntax
# LLM_API_KEY=...
# LLM_BASE_URL=http://localhost:4000     # your litellm proxy URL

# --- Groq --------------------------------------------------------------------
# LLM_PROVIDER=groq
# LLM_MODEL=llama3-70b-8192
# LLM_API_KEY=gsk_...

# --- Ollama (local) ----------------------------------------------------------
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:latest
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- DeepSeek ----------------------------------------------------------------
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-...

# --- Together AI -------------------------------------------------------------
# LLM_PROVIDER=together
# LLM_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
# LLM_API_KEY=...

# --- AWS Bedrock -------------------------------------------------------------
# LLM_PROVIDER=aws_bedrock
# LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# --- Azure OpenAI ------------------------------------------------------------
# LLM_PROVIDER=azure_openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=...
# LLM_BASE_URL=https://<resource>.openai.azure.com/

# --- Mistral AI --------------------------------------------------------------
# LLM_PROVIDER=mistralai
# LLM_MODEL=mistral-large-latest
# LLM_API_KEY=...

# --- LM Studio (local) -------------------------------------------------------
# LLM_PROVIDER=lmstudio
# LLM_MODEL=your-model-name
# LLM_BASE_URL=http://host.docker.internal:1234/v1

# --- vLLM (local/self-hosted) ------------------------------------------------
# LLM_PROVIDER=vllm
# LLM_MODEL=your-model-name
# LLM_BASE_URL=http://host.docker.internal:8000/v1

# =============================================================================
# Embedder Provider  (pick ONE block, comment out the rest)
# =============================================================================

# --- OpenAI ------------------------------------------------------------------
# EMBEDDER_PROVIDER=openai
# EMBEDDER_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...                  # reuses LLM key if same provider

# --- Google Gemini -----------------------------------------------------------
# EMBEDDER_PROVIDER=google
# EMBEDDER_MODEL=models/text-embedding-004
# EMBEDDER_API_KEY=AIza...

# --- Vertex AI ---------------------------------------------------------------
# EMBEDDER_PROVIDER=vertexai
# EMBEDDER_MODEL=text-embedding-004
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# GOOGLE_CLOUD_PROJECT=your-project-id

# --- Ollama (local) ----------------------------------------------------------
# EMBEDDER_PROVIDER=ollama
# EMBEDDER_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Hugging Face ------------------------------------------------------------
# EMBEDDER_PROVIDER=huggingface
# EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- FastEmbed (local, no API key needed) ------------------------------------
# EMBEDDER_PROVIDER=fastembed
# EMBEDDER_MODEL=BAAI/bge-small-en-v1.5

# --- Azure OpenAI ------------------------------------------------------------
# EMBEDDER_PROVIDER=azure_openai
# EMBEDDER_MODEL=text-embedding-ada-002
# EMBEDDER_API_KEY=...
# EMBEDDER_BASE_URL=https://<resource>.openai.azure.com/

# --- Together AI -------------------------------------------------------------
# EMBEDDER_PROVIDER=together
# EMBEDDER_MODEL=togethercomputer/m2-bert-80M-8k-retrieval
# EMBEDDER_API_KEY=...

# --- AWS Bedrock -------------------------------------------------------------
# EMBEDDER_PROVIDER=aws_bedrock
# EMBEDDER_MODEL=amazon.titan-embed-text-v2:0
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# --- LM Studio (local) -------------------------------------------------------
# EMBEDDER_PROVIDER=lmstudio
# EMBEDDER_MODEL=your-embedding-model
# EMBEDDER_BASE_URL=http://host.docker.internal:1234/v1

# =============================================================================
# Vector Store  (default: Qdrant — already started by docker-compose)
# Uncomment a block only if you want to use something other than Qdrant.
# =============================================================================

# QDRANT_HOST and QDRANT_PORT are always set by docker-compose.dev.yml.
# Override here only if pointing at an external Qdrant instance:
# QDRANT_HOST=your-qdrant-host
# QDRANT_PORT=6333

# --- Chroma ------------------------------------------------------------------
# CHROMA_HOST=chroma
# CHROMA_PORT=8000

# --- Weaviate ----------------------------------------------------------------
# WEAVIATE_CLUSTER_URL=http://weaviate:8080

# --- Redis -------------------------------------------------------------------
# REDIS_URL=redis://redis:6379

# --- pgvector ----------------------------------------------------------------
# PG_HOST=postgres
# PG_PORT=5432
# PG_DB=mem0
# PG_USER=mem0
# PG_PASSWORD=mem0

# --- Milvus ------------------------------------------------------------------
# MILVUS_HOST=milvus
# MILVUS_PORT=19530

# --- Elasticsearch -----------------------------------------------------------
# ELASTICSEARCH_HOST=elasticsearch
# ELASTICSEARCH_PORT=9200
# ELASTICSEARCH_USER=elastic
# ELASTICSEARCH_PASSWORD=changeme

# --- OpenSearch --------------------------------------------------------------
# OPENSEARCH_HOST=opensearch
# OPENSEARCH_PORT=9200

# --- FAISS (local file) ------------------------------------------------------
# FAISS_PATH=/data/faiss
